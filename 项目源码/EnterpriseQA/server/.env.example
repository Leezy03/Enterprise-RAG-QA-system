# Flask / JWT
SECRET_KEY=change-this-secret-key

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=db_enterprise_qa

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=qwen3:4b
OLLAMA_EMBED_MODEL=qwen3-embedding:4b

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_data

# RAG
RAG_HISTORY_TURNS=3
RETRIEVER_TOP_K=4

# Chunking
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TXT_CHUNK_SIZE=500
TXT_CHUNK_OVERLAP=50
PDF_CHUNK_SIZE=450
PDF_CHUNK_OVERLAP=80
MD_CHUNK_SIZE=800
MD_CHUNK_OVERLAP=100
DOCX_CHUNK_SIZE=700
DOCX_CHUNK_OVERLAP=100

RERANK_ENABLED=true
RERANK_CANDIDATE_K=12
HYBRID_SEARCH_ENABLED=true
HYBRID_KEYWORD_CANDIDATE_K=12
HYBRID_KEYWORD_SCAN_LIMIT=2000
HYBRID_RRF_K=60
BM25_K1=1.5
BM25_B=0.75
BM25_INCLUDE_METADATA=true
